<!doctype html>
<html lang="id">
<head>
	<meta charset="utf-8" />
	<meta name="viewport" content="width=device-width, initial-scale=1.0" />
	<title>Riwayat Booking — Arena Booking</title>
	<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
	<script src="https://cdn.tailwindcss.com"></script>
	<script>tailwind.config = { theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 50: '#eff6ff', 500: '#3b82f6', 600: '#2563eb', 700: '#1d4ed8' } } } } }</script>
</head>
<body class="bg-slate-50 text-slate-800 antialiased min-h-screen flex flex-col">

	<header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
		<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
			<div class="flex justify-between items-center h-16">
				<div class="flex items-center gap-2">
					<div class="bg-brand-600 text-white p-2 rounded-lg"><i class="ph ph-soccer-ball text-2xl"></i></div>
					<a href="/" class="font-bold text-xl text-slate-900 tracking-tight">Arena<span class="text-brand-600">Booking</span></a>
				</div>
				<nav class="flex items-center gap-4">
					<a href="/" class="text-sm font-medium text-slate-500 hover:text-brand-600 transition-colors">Beranda</a>
					<a href="/dashboard-user" class="text-sm font-medium text-slate-500 hover:text-brand-600 transition-colors">Dashboard</a>
					<button onclick="logout()" class="text-sm font-medium px-4 py-2 bg-rose-50 text-rose-600 rounded-md hover:bg-rose-100 transition-colors">Logout</button>
				</nav>
			</div>
		</div>
	</header>

	<main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full">
		<div class="bg-white rounded-2xl p-6 sm:p-8 mb-6 shadow">
			<h1 class="text-2xl font-bold mb-2">Riwayat Booking</h1>
			<p class="text-sm text-slate-500">Riwayat semua booking Anda. Unggah bukti pembayaran dari sini jika belum diunggah.</p>
		</div>

		<div class="bg-white rounded-xl shadow p-6">
			<div class="overflow-x-auto">
				<table class="min-w-full text-sm">
					<thead>
						<tr class="text-left text-slate-500 border-b">
							<th class="px-4 py-3">#</th>
							<th class="px-4 py-3">Lapangan</th>
							<th class="px-4 py-3">Tanggal</th>
							<th class="px-4 py-3">Jam</th>
							<th class="px-4 py-3">Status</th>
							<th class="px-4 py-3">Bukti</th>
							<th class="px-4 py-3">Aksi</th>
						</tr>
					</thead>
					<tbody id="riwayat-table-body" class="divide-y"></tbody>
				</table>
			</div>
		</div>
	</main>

	<script>
		const token = localStorage.getItem('token');
		if(!token) window.location.href = '/login';

		function logout(){ localStorage.removeItem('token'); window.location.href = '/'; }

		function el(tag, attrs={}, text=''){ const e = document.createElement(tag); Object.entries(attrs).forEach(([k,v])=> e.setAttribute(k,v)); if(text) e.textContent = text; return e; }

		async function loadRiwayat(){
			try{
				const res = await fetch('/booking/riwayat', { headers: { 'Authorization': 'Bearer ' + token } });
				const ct = res.headers.get('content-type') || '';
				let data = ct.includes('application/json') ? await res.json() : [];
				const tbody = document.getElementById('riwayat-table-body'); tbody.innerHTML='';
				if(!data || data.length===0){ tbody.innerHTML = '<tr><td class="p-4" colspan="7">Belum ada riwayat</td></tr>'; return; }
				data.forEach((r, idx)=>{
					const tr = document.createElement('tr');
					tr.innerHTML = `
						<td class="px-4 py-3">${idx+1}</td>
						<td class="px-4 py-3 font-medium">${r.nama_lapangan||('ID:'+r.lapangan_id)}</td>
						<td class="px-4 py-3">${r.tanggal}</td>
						<td class="px-4 py-3">${r.jam_mulai} - ${r.jam_selesai}</td>
						<td class="px-4 py-3">${r.status}</td>
						<td class="px-4 py-3">${r.bukti_pembayaran ? `<a class=\"text-sm text-brand-600 underline\" href=\"/uploads/${r.bukti_pembayaran}\" target=\"_blank\">Lihat</a>` : 'Belum'}</td>
						<td class="px-4 py-3" id="aksi-${r.id}"></td>
					`;

					tbody.appendChild(tr);

					// add aksi (upload) if bukti kosong
					if(!r.bukti_pembayaran){
						const aksiTd = document.getElementById('aksi-'+r.id);
						const form = el('form', { 'data-id': r.id }, '');
						const file = document.createElement('input'); file.type='file'; file.name='bukti'; file.accept='image/*'; file.className='mr-2';
						const btn = el('button', { type:'button', class:'bg-brand-600 text-white px-3 py-1 rounded' }, 'Upload');
						btn.addEventListener('click', async ()=>{
							if(!file.files || file.files.length===0) return alert('Pilih file terlebih dahulu');
							const fd = new FormData(); fd.append('bukti', file.files[0]);
							try{
								const up = await fetch(`/booking/upload/${r.id}`, { method:'POST', headers: { 'Authorization': 'Bearer ' + token }, body: fd });
								const ct2 = up.headers.get('content-type') || '';
								const resj = ct2.includes('application/json') ? await up.json() : await up.text();
								if(!up.ok) throw new Error((resj && resj.message) ? resj.message : (typeof resj === 'string' ? resj : 'Gagal upload'));
								alert('Bukti berhasil diupload'); loadRiwayat();
							}catch(e){ alert(e.message || e); }
						});
						aksiTd.appendChild(file); aksiTd.appendChild(btn);
					}
				});
			}catch(e){ console.error(e); document.getElementById('riwayat-table-body').innerHTML = '<tr><td class="p-4" colspan="7">Gagal memuat riwayat</td></tr>'; }
		}

		loadRiwayat();
	</script>

</body>
</html>

