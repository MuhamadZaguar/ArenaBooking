<!doctype html>
<html lang="id">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Admin Dashboard — Arena Booking</title>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <script src="https://cdn.tailwindcss.com"></script>
  <link rel="stylesheet" href="/styles.css" />
  <script src="https://unpkg.com/@phosphor-icons/web"></script>
  <script>tailwind.config = { theme: { extend: { fontFamily: { sans: ['Inter', 'sans-serif'] }, colors: { brand: { 600: '#2563eb', 900: '#1e3a8a' } } } } }</script>
</head>
<body class="bg-slate-50 text-slate-800 antialiased min-h-screen flex flex-col">

  <header class="bg-white border-b border-slate-200 sticky top-0 z-40 shadow-sm">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 flex justify-between items-center h-16">
      <div class="flex items-center gap-2">
        <div class="bg-brand-600 text-white p-2 rounded-lg"><i class="ph ph-soccer-ball text-2xl"></i></div>
        <a href="/" class="font-bold text-xl text-slate-900">Arena<span class="text-brand-600">Booking</span></a>
      </div>
      <button onclick="logoutAdmin()" class="text-rose-500 text-sm font-semibold flex items-center gap-1 hover:text-rose-700"><i class="ph ph-sign-out"></i> Logout</button>
    </div>
  </header>

  <main class="flex-1 max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8 w-full container-centered">
    <div class="mb-8">
      <h1 class="text-2xl font-bold text-slate-900">Pusat Manajemen Booking</h1>
      <p class="text-slate-500 mt-1">Review dan verifikasi permintaan booking dari pelanggan.</p>
    </div>

      <!-- Form tambah lapangan (admin) -->
  <section class="card overflow-hidden mb-8">
        <div class="px-6 py-5 border-b border-slate-200 bg-slate-50/50">
          <h3 class="text-lg font-semibold text-slate-800">Tambah Lapangan Baru</h3>
          <p class="text-sm text-slate-500 mt-1">Isi data lapangan untuk ditampilkan ke pengguna.</p>
        </div>
  <div class="p-6">
          <form id="add-lapangan-form" class="grid grid-cols-1 md:grid-cols-3 gap-4">
            <div class="md:col-span-2">
              <label class="block text-sm font-medium text-slate-700 mb-1">Nama Lapangan</label>
              <input name="nama_lapangan" required class="w-full px-3 py-2 border border-slate-200 rounded-md" placeholder="Contoh: Lapangan A" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Jenis Olahraga</label>
              <input name="jenis_olahraga" class="w-full px-3 py-2 border border-slate-200 rounded-md" placeholder="Futsal / Basket" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Lokasi</label>
              <input name="lokasi" class="w-full px-3 py-2 border border-slate-200 rounded-md" placeholder="Contoh: Jalan Merdeka No.1" />
            </div>
            <div>
              <label class="block text-sm font-medium text-slate-700 mb-1">Harga per jam</label>
              <input name="harga_per_jam" required type="number" class="w-full px-3 py-2 border border-slate-200 rounded-md" placeholder="50000" />
            </div>
            <div class="md:col-span-3">
              <label class="block text-sm font-medium text-slate-700 mb-1">Deskripsi</label>
              <textarea name="deskripsi" class="w-full px-3 py-2 border border-slate-200 rounded-md" rows="2" placeholder="Deskripsi singkat lapangan"></textarea>
            </div>
            <div class="md:col-span-3 text-right">
              <button type="submit" class="btn-primary">Tambahkan Lapangan</button>
            </div>
          </form>
        </div>
      </section>

    <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden">
      <div class="px-6 py-5 border-b border-slate-200 bg-slate-50/50 flex justify-between items-center">
        <h3 class="text-lg font-semibold text-slate-800 flex items-center gap-2"><i class="ph ph-list-checks text-brand-600 text-xl"></i> Menunggu Verifikasi</h3>
        <button onclick="loadPending()" class="text-sm text-brand-600 bg-brand-50 px-3 py-1.5 rounded-lg border border-brand-100 hover:bg-brand-100 transition"><i class="ph ph-arrows-clockwise"></i> Refresh</button>
      </div>
      
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left whitespace-nowrap">
          <thead class="text-xs text-slate-500 uppercase bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="px-6 py-4">User</th>
              <th class="px-6 py-4">Lapangan</th>
              <th class="px-6 py-4">Jadwal</th>
              <th class="px-6 py-4">Bukti</th>
              <th class="px-6 py-4 text-center">Aksi</th>
            </tr>
          </thead>
          <tbody id="pending-tbody" class="divide-y divide-slate-200">
            <tr><td colspan="5" class="text-center py-8 text-slate-500"><i class="ph ph-spinner animate-spin"></i> Memuat data...</td></tr>
          </tbody>
        </table>
      </div>
    </section>

    <!-- Daftar Lapangan (admin) -->
    <section class="bg-white rounded-xl shadow-sm border border-slate-200 overflow-hidden mt-8">
      <div class="px-6 py-5 border-b border-slate-200 bg-slate-50/50 flex justify-between items-center">
        <h3 class="text-lg font-semibold text-slate-800 flex items-center gap-2"><i class="ph ph-soccer-ball text-brand-600 text-xl"></i> Kelola Lapangan</h3>
        <button onclick="loadLapangan()" class="text-sm text-brand-600 bg-brand-50 px-3 py-1.5 rounded-lg border border-brand-100 hover:bg-brand-100 transition"><i class="ph ph-arrows-clockwise"></i> Refresh</button>
      </div>
      <div class="overflow-x-auto">
        <table class="w-full text-sm text-left whitespace-nowrap">
          <thead class="text-xs text-slate-500 uppercase bg-slate-50 border-b border-slate-200">
            <tr>
              <th class="px-6 py-4">ID</th>
              <th class="px-6 py-4">Nama</th>
              <th class="px-6 py-4">Jenis</th>
              <th class="px-6 py-4">Harga / jam</th>
              <th class="px-6 py-4">Aksi</th>
            </tr>
          </thead>
          <tbody id="lapangan-tbody" class="divide-y divide-slate-200">
            <tr><td colspan="5" class="text-center py-8 text-slate-500"><i class="ph ph-spinner animate-spin"></i> Memuat daftar lapangan...</td></tr>
          </tbody>
        </table>
      </div>
    </section>
  </main>

  <script>
    // Gunakan token dan role yang sama seperti di login
    const token = localStorage.getItem('token');
    const role = localStorage.getItem('role');
    // Pastikan token ada dan user adalah admin
    if(!token || role !== 'admin') {
      // redirect ke halaman login jika tidak memiliki akses
      window.location.replace('/login');
    }

    function logoutAdmin() {
      localStorage.removeItem('token');
      localStorage.removeItem('role');
      window.location.replace('/');
    }

    async function loadPending() {
      try {
  const res = await fetch('/admin/booking-menunggu', { headers: { 'Authorization': 'Bearer ' + token } });
        const data = await res.json();
        const tbody = document.getElementById('pending-tbody');
        
        if(!data.length) return tbody.innerHTML = `<tr><td colspan="5" class="text-center py-8 text-slate-500">Tidak ada booking menunggu.</td></tr>`;

        tbody.innerHTML = data.map(r => {
          const bukti = r.bukti_bayar ? `<a href="/uploads/${r.bukti_bayar}" target="_blank" class="text-brand-600 underline text-xs"><i class="ph ph-image"></i> Lihat</a>` : `<span class="text-slate-400 text-xs">-</span>`;
          return `
          <tr class="hover:bg-slate-50">
            <td class="px-6 py-4 font-medium text-slate-900">${r.nama || r.nama_user || 'User'}</td>
            <td class="px-6 py-4 text-slate-700">${r.lapangan_id}</td>
            <td class="px-6 py-4 text-slate-600">${r.tanggal} <br/><span class="text-xs text-slate-400">${r.jam_mulai}</span></td>
            <td class="px-6 py-4">${bukti}</td>
            <td class="px-6 py-4 text-center space-x-2">
              <button onclick="verify('${r.id}', 'verifikasi')" class="bg-emerald-50 text-emerald-600 px-3 py-1.5 rounded text-sm hover:bg-emerald-100">Terima</button>
              <button onclick="verify('${r.id}', 'tolak')" class="bg-rose-50 text-rose-600 px-3 py-1.5 rounded text-sm hover:bg-rose-100">Tolak</button>
            </td>
          </tr>
        `}).join('');
      } catch(e) { console.error(e); }
    }

    async function verify(id, mode) {
      if(!confirm(`Yakin ingin ${mode}?`)) return;
      try {
  const res = await fetch(`/admin/${mode === 'verifikasi' ? 'verifikasi' : 'tolak'}/${id}`, { method: 'PUT', headers: { 'Authorization': 'Bearer ' + token } });
        if(!res.ok) throw new Error('Gagal');
        loadPending();
      } catch(e) { alert('Gagal melakukan aksi'); }
    }

    loadPending();
  </script>
  <script>
    // handler tambah lapangan
    document.addEventListener('DOMContentLoaded', ()=>{
      const form = document.getElementById('add-lapangan-form');
      if(!form) return;
      form.addEventListener('submit', async (ev)=>{
        ev.preventDefault();
        const fd = new FormData(form);
        const payload = {
          nama_lapangan: fd.get('nama_lapangan'),
          jenis_olahraga: fd.get('jenis_olahraga'),
          lokasi: fd.get('lokasi'),
          harga_per_jam: Number(fd.get('harga_per_jam')) || 0,
          deskripsi: fd.get('deskripsi')
        };
        const token = localStorage.getItem('token');
        try{
          const res = await fetch('/lapangan', { method: 'POST', headers: { 'Content-Type': 'application/json', 'Authorization': 'Bearer ' + token }, body: JSON.stringify(payload) });
          const ct = res.headers.get('content-type') || '';
          const data = ct.includes('application/json') ? await res.json() : { message: await res.text() };
          if(!res.ok) throw new Error((data && data.message) ? data.message : 'Gagal menambah lapangan');
          // success: show message and reset
          alert((data && data.message) ? data.message + (data.id ? ' (ID: '+data.id+')' : '') : 'Berhasil');
          form.reset();
        } catch(e){
          // show server message if available
          alert(e.message || 'Gagal menambah lapangan');
        }
      });
    });
  </script>
    <script>
      // load lapangan list and render edit buttons
      async function loadLapangan(){
        try{
          const res = await fetch('/lapangan');
          if(!res.ok) throw new Error('Gagal memuat');
          const data = await res.json();
          const tbody = document.getElementById('lapangan-tbody');
          if(!data || !data.length) return tbody.innerHTML = `<tr><td colspan="5" class="text-center py-8 text-slate-500">Belum ada lapangan.</td></tr>`;
          tbody.innerHTML = data.map(r => `
            <tr class="hover:bg-slate-50">
              <td class="px-6 py-4 font-medium text-slate-900">${r.id}</td>
              <td class="px-6 py-4 text-slate-700">${r.nama_lapangan}</td>
              <td class="px-6 py-4 text-slate-600">${r.jenis_olahraga || '-'}</td>
              <td class="px-6 py-4 text-slate-700">Rp ${Number(r.harga_per_jam).toLocaleString('id-ID')}</td>
              <td class="px-6 py-4 text-right">
                <button onclick="window.location.href='/lapangan/edit/${r.id}'" class="px-3 py-1.5 bg-amber-50 text-amber-700 rounded text-sm hover:bg-amber-100">Edit</button>
                <button onclick="deleteLapangan(${r.id})" class="px-3 py-1.5 bg-rose-50 text-rose-700 rounded text-sm hover:bg-rose-100 ml-2">Hapus</button>
              </td>
            </tr>
          `).join('');
        }catch(e){ console.error(e); }
      }

      async function deleteLapangan(id){
        if(!confirm('Yakin ingin menghapus lapangan ini?')) return;
        try{
          const token = localStorage.getItem('token');
          const res = await fetch('/lapangan/' + id, { method: 'DELETE', headers: { 'Authorization': 'Bearer ' + token } });
          if(!res.ok) throw new Error('Gagal menghapus');
          alert('Lapangan dihapus');
          loadLapangan();
        }catch(e){ alert(e.message || 'Gagal menghapus'); }
      }

      // initial load for lapangan list
      document.addEventListener('DOMContentLoaded', ()=>{ loadLapangan(); });
    </script>
</body>
</html>